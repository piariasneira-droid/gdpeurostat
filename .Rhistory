# animated_dispersion.R
# Reads the parquet, builds an animated scatter (EU NUTS2 GDP dispersion)
# highlighting Spain across all available years, and saves a .gif ----
# Libraries ----
library(arrow)
library(tidyverse)
library(ggrepel)
library(gganimate)
library(gifski)
# Config ----
PARQUET_PATH <- "./data/output/gdp_eurostat_nuts2+0.parquet"
OUTPUT_PATH  <- "./output/dispersion_eu_nuts2_animated.gif"
COUNTRY      <- "ES"   # highlighted country
VARX         <- "MIO_PPS_EU27_2020"
VARY         <- "PPS_HAB_EU27_2020"
# Spanish region short labels ----
ES_LABELS <- c(
ES11 = "GAL", ES12 = "AST", ES13 = "CANT",
ES21 = "PV",  ES22 = "NAV", ES23 = "RIO",
ES24 = "ARA", ES30 = "MAD", ES41 = "CYL",
ES42 = "CLM", ES43 = "EXT", ES51 = "CAT",
ES52 = "VAL", ES53 = "BAL", ES61 = "AND",
ES62 = "MUR", ES63 = "CEU", ES64 = "MEL",
ES70 = "CAN"
)
# Colour palette (consistent with the rest of the project) ----
COL_OTHER    <- "#A0B8C8"   # other EU regions
COL_EU_LINE  <- "#DC5924"   # EU reference line
COL_ES_OTHER <- "#F5C201"   # Spanish non-Madrid regions
COL_MADRID   <- "#526DB0"   # Madrid / capital
# Theme (replicates custom_theme from proces_pib.R) ----
custom_theme <- theme(
panel.background    = element_rect(fill = "white",       color = NA),
plot.background     = element_rect(fill = "white",       color = NA),
plot.title          = element_text(size = 14, face = "bold",  color = "#222", hjust = 0.5),
plot.subtitle       = element_text(size = 11, color = "#555", hjust = 0.5),
axis.title          = element_text(size = 11, color = "#333"),
axis.text           = element_text(size = 9,  color = "#333"),
axis.ticks          = element_line(color = "#bbb"),
axis.line           = element_line(color = "#bbb"),
panel.grid.major.x  = element_blank(),
panel.grid.minor.x  = element_blank(),
panel.grid.major.y  = element_line(color = "#e5e5e5", linewidth = 0.4, linetype = "dashed"),
panel.grid.minor.y  = element_blank(),
legend.background   = element_rect(fill = "white",       color = NA),
legend.box.background = element_rect(fill = "white",     color = NA),
legend.position     = "bottom",
legend.justification = "right",
legend.text         = element_text(size = 9),
legend.title        = element_text(size = 10, face = "bold"),
plot.caption        = element_text(size = 8, hjust = 0, color = "#666"),
plot.margin         = margin(t = 10, r = 15, b = 10, l = 10)
)
# Read & prepare data ----
message("Reading parquet...")
ds <- open_dataset(PARQUET_PATH)
dat_wide <- ds %>%
filter(
var    %in% !!c(VARX, VARY),
nombre != "Extra-Regio NUTS 2",
level  == 2L
) %>%
collect() %>%
pivot_wider(names_from = var, values_from = valor) %>%
mutate(
country    = substr(code, 1, 2),
es_label   = ES_LABELS[code],
region_type = case_when(
code    == "ES30"    ~ "Madrid",
country == COUNTRY   ~ "Spain (other)",
TRUE                 ~ "Other EU"
),
# keep label only for Spain; NA elsewhere (ggrepel ignores NA)
label_text = if_else(country == COUNTRY, coalesce(es_label, code), NA_character_)
)
eu_avg <- ds %>%
filter(
var  == !!VARY,
code == "EU27_2020"
) %>%
collect() %>%
select(ano, eu_avg = valor)
dat_wide <- dat_wide %>%
left_join(eu_avg, by = "ano")
years <- sort(unique(dat_wide$ano))
message(sprintf("Years found: %s", paste(years, collapse = ", ")))
# Build plot ----
message("Building animated plot...")
# Fixed axis limits so the frame doesn't jump ----
x_lim <- range(dat_wide[[VARX]], na.rm = TRUE) * c(0.98, 1.02)
y_lim <- range(dat_wide[[VARY]],  na.rm = TRUE) * c(0.95, 1.05)
colour_map <- c(
"Madrid"        = COL_MADRID,
"Spain (other)" = COL_ES_OTHER,
"Other EU"      = COL_OTHER
)
size_map <- c(
"Madrid"        = 4.5,
"Spain (other)" = 3.5,
"Other EU"      = 2.0
)
alpha_map <- c(
"Madrid"        = 1.0,
"Spain (other)" = 0.9,
"Other EU"      = 0.55
)
p <- ggplot(dat_wide,
aes(x     = .data[[VARX]],
y     = .data[[VARY]],
color = region_type,
size  = region_type,
alpha = region_type)) +
# EU average horizontal line (drawn as geom_hline per frame via geom_segment) ----
geom_hline(
aes(yintercept = eu_avg),
color     = COL_EU_LINE,
linewidth = 0.6,
linetype  = "dotted"
) +
# All region points ----
geom_point(shape = 16) +
# Spanish region labels (repelled) ----
geom_text_repel(
aes(label = label_text),
size          = 2.8,
color         = "#222",
box.padding   = 0.45,
point.padding = 0.3,
force         = 2,
max.overlaps  = Inf,
show.legend   = FALSE,
na.rm         = TRUE,
segment.color = "#aaa",
segment.size  = 0.3
) +
# EU avg annotation (static text anchored top-right each frame) ----
geom_text(
data = eu_avg,
aes(x = x_lim[2] * 0.97,
y = eu_avg,
label = paste0("EU avg: ", round(eu_avg))),
inherit.aes = FALSE,
hjust       = 1,
vjust       = -0.4,
size        = 2.8,
color       = COL_EU_LINE
) +
# Scales ----
scale_color_manual(
values = colour_map,
name   = "Region type",
breaks = c("Madrid", "Spain (other)", "Other EU"),
labels = c("Madrid", "Spain – other NUTS2", "Other EU NUTS2")
) +
scale_size_manual(values  = size_map,  guide = "none") +
scale_alpha_manual(values = alpha_map, guide = "none") +
scale_x_continuous(
labels = function(x) format(x / 1000, big.mark = ",", scientific = FALSE),
limits = x_lim,
expand = c(0, 0)
) +
scale_y_continuous(
labels = function(x) format(x, big.mark = ",", scientific = FALSE),
limits = y_lim,
expand = c(0, 0)
) +
labs(
title    = "EU NUTS2 GDP Dispersion – Year: {current_frame}",
subtitle = "Total GDP (x) vs GDP per capita in PPS (y) | Spain highlighted",
x        = "Total GDP in PPS 2020 (billions)",
y        = "GDP per capita in PPS 2020",
caption  = "Source: Eurostat. Dotted line = EU27 average GDP per capita."
) +
custom_theme +
theme(legend.position = "bottom") +
# Animation ----
transition_manual(ano)
# Render & save ----
message("Rendering GIF (this may take a minute)...")
dir.create(dirname(OUTPUT_PATH), showWarnings = FALSE, recursive = TRUE)
n_years <- length(years)
anim <- animate(
p,
nframes  = n_years * 4,    # 4 intermediate frames per year for smooth feel
fps      = 6,              # 4 frames × 6 fps → ~1.5 s per year step
width    = 1000,
height   = 700,
res      = 110,
renderer = gifski_renderer(OUTPUT_PATH)
)
message("Done! GIF saved to: ", OUTPUT_PATH)
p
print(p)
source("~/Documentos/pibeurostat/scr/animated_dispersion.R")
View(dat_wide)
shiny::runApp('shiny')
